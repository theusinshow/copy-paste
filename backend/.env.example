APP_NAME=Copy&Paste Backend
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/copy_paste
UPLOAD_DIR=./uploads
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
# Opcional: chave Groq para analise assistida por IA (https://console.groq.com)
GROQ_API_KEY=
